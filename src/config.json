{
  "//": "DO NOT EDIT THIS FILE before reading the comments below:",

  "//": "This is the default configuration for Tiny Tapeout projects. It should fit most designs.",
  "//": "If you change it, please make sure you understand what you are doing. We are not responsible",
  "//": "if your project fails because of a bad configuration.",

  "//": "!!! DO NOT EDIT THIS FILE unless you know what you are doing !!!",

  "//": "If you get stuck with this config, please open an issue or get in touch via the discord.",

  "//": "Here are some of the variables you may want to change:",

  "//": "PL_TARGET_DENSITY_PCT - You can increase this if Global Placement fails with error GPL-0302.",
  "//": "Users have reported that values up to 80 worked well for them.",
  "PL_TARGET_DENSITY_PCT": 50,

  "//": "CLOCK_PERIOD - Increase this in case you are getting setup time violations.",
  "//": "The value is in nanoseconds, so 20ns == 50MHz.",
  "CLOCK_PERIOD": 20,

  "//": "Hold slack margin - Increase them in case you are getting hold violations.",
  "PL_RESIZER_HOLD_SLACK_MARGIN": 0.1,
  "GRT_RESIZER_HOLD_SLACK_MARGIN": 0.05,

  "//": "RUN_LINTER, LINTER_INCLUDE_PDK_MODELS - Disabling the linter is not recommended!",
  "RUN_LINTER": 1,
  "LINTER_INCLUDE_PDK_MODELS": 1,

  "//": "If you need a custom clock configuration, read the following documentation first:",
  "//": "https://tinytapeout.com/faq/#how-can-i-map-an-additional-external-clock-to-one-of-the-gpios",
  "CLOCK_PORT": "clk",

  "//": "Verilog include path for kianv-sv32-tt subdirectory",
  "VERILOG_INCLUDE_DIRS": "dir::kianv-sv32-tt",

  "//": "Configuration docs: https://librelane.readthedocs.io/en/latest/reference/configuration.html",

  "//": "SRAM macro integration: regfile (2P_64x32) + icache/dcache (1P_64x64)",
  "MACROS": {
    "RM_IHPSG13_2P_64x32_c2": {
      "instances": {
        "soc_I.kianv_I.datapath_unit_I.register_file_I.u_sram_rd1": {
          "location": [40, 40],
          "orientation": "N"
        }
      },
      "gds": ["dir::../macro/RM_IHPSG13_2P_64x32_c2/RM_IHPSG13_2P_64x32_c2.gds"],
      "lef": ["dir::../macro/RM_IHPSG13_2P_64x32_c2/RM_IHPSG13_2P_64x32_c2.lef"],
      "lib": {
        "nom_*": ["dir::../macro/RM_IHPSG13_2P_64x32_c2/RM_IHPSG13_2P_64x32_c2_typ_1p20V_25C.lib"],
        "min_*": ["dir::../macro/RM_IHPSG13_2P_64x32_c2/RM_IHPSG13_2P_64x32_c2_fast_1p32V_m55C.lib"],
        "max_*": ["dir::../macro/RM_IHPSG13_2P_64x32_c2/RM_IHPSG13_2P_64x32_c2_slow_1p08V_125C.lib"],
        "*": ["dir::../macro/RM_IHPSG13_2P_64x32_c2/RM_IHPSG13_2P_64x32_c2_typ_1p20V_25C.lib"]
      },
      "nl": ["dir::./RM_IHPSG13_2P_64x32_c2.v"],
      "spice": ["dir::../macro/RM_IHPSG13_2P_64x32_c2/RM_IHPSG13_2P_64x32_c2.cdl"]
    },
    "RM_IHPSG13_1P_64x64_c2_bm_bist": {
      "instances": {
        "soc_I.cache_I.gen_cached.icache_I.cache_I.gen_sram64.u_mem.gen_ihp_sg13.u_sram64": {
          "location": [860, 40],
          "orientation": "N"
        },
        "soc_I.cache_I.gen_cached.dcache_I.cache_D.gen_sram64.u_mem.gen_ihp_sg13.u_sram64": {
          "location": [40, 600],
          "orientation": "N"
        }
      },
      "gds": ["dir::../macro/RM_IHPSG13_1P_64x64_c2_bm_bist/RM_IHPSG13_1P_64x64_c2_bm_bist.gds"],
      "lef": ["dir::../macro/RM_IHPSG13_1P_64x64_c2_bm_bist/RM_IHPSG13_1P_64x64_c2_bm_bist.lef"],
      "lib": {
        "nom_*": ["dir::../macro/RM_IHPSG13_1P_64x64_c2_bm_bist/RM_IHPSG13_1P_64x64_c2_bm_bist_typ_1p20V_25C.lib"],
        "min_*": ["dir::../macro/RM_IHPSG13_1P_64x64_c2_bm_bist/RM_IHPSG13_1P_64x64_c2_bm_bist_fast_1p32V_m55C.lib"],
        "max_*": ["dir::../macro/RM_IHPSG13_1P_64x64_c2_bm_bist/RM_IHPSG13_1P_64x64_c2_bm_bist_slow_1p08V_125C.lib"],
        "*": ["dir::../macro/RM_IHPSG13_1P_64x64_c2_bm_bist/RM_IHPSG13_1P_64x64_c2_bm_bist_typ_1p20V_25C.lib"]
      },
      "nl": ["dir::./RM_IHPSG13_1P_64x64_c2_bm_bist.v"],
      "spice": ["dir::../macro/RM_IHPSG13_1P_64x64_c2_bm_bist/RM_IHPSG13_1P_64x64_c2_bm_bist.cdl"]
    }
  },

  "PDN_MACRO_CONNECTIONS": [
    "soc_I.kianv_I.datapath_unit_I.register_file_I.u_sram_rd1 VPWR VGND VDD! VSS!",
    "soc_I.kianv_I.datapath_unit_I.register_file_I.u_sram_rd1 VPWR VGND VDDARRAY! VSS!",
    "soc_I.cache_I.gen_cached.icache_I.cache_I.gen_sram64.u_mem.gen_ihp_sg13.u_sram64 VPWR VGND VDD! VSS!",
    "soc_I.cache_I.gen_cached.icache_I.cache_I.gen_sram64.u_mem.gen_ihp_sg13.u_sram64 VPWR VGND VDDARRAY! VSS!",
    "soc_I.cache_I.gen_cached.dcache_I.cache_D.gen_sram64.u_mem.gen_ihp_sg13.u_sram64 VPWR VGND VDD! VSS!",
    "soc_I.cache_I.gen_cached.dcache_I.cache_D.gen_sram64.u_mem.gen_ihp_sg13.u_sram64 VPWR VGND VDDARRAY! VSS!"
  ],

  "//": "Custom PDN config: SRAM power pins on Metal4, connect Metal4 -> TopMetal1",
  "PDN_CFG": "dir::pdn_cfg.tcl",

  "//": "Routing obstructions over SRAM footprints",
  "//": "Regfile 2P_64x32: 702.83 x 74.87 µm at [40,40]",
  "//": "Cache 1P_64x64: 784.48 x 64.36 µm at [860,40] and [40,600]",
  "ROUTING_OBSTRUCTIONS": [
    "Metal3 40.00 39.40 742.83 40.00",
    "Metal3 40.00 114.87 742.83 115.47",
    "Metal3 39.40 40.00 40.00 114.87",
    "Metal3 742.83 40.00 743.43 114.87",
    "Metal2 40.00 114.87 742.83 115.47",
    "Metal2 39.40 40.00 40.00 114.87",
    "Metal2 742.83 40.00 743.43 114.87",
    "Metal4 40.00 40.00 742.83 114.87",
    "Metal5 40.00 40.00 742.83 114.87",
    "TopMetal1 40.00 40.00 742.83 114.87",

    "Metal3 860.00 39.40 1644.48 40.00",
    "Metal3 860.00 104.36 1644.48 104.96",
    "Metal3 859.40 40.00 860.00 104.36",
    "Metal3 1644.48 40.00 1645.08 104.36",
    "Metal2 860.00 104.36 1644.48 104.96",
    "Metal2 859.40 40.00 860.00 104.36",
    "Metal2 1644.48 40.00 1645.08 104.36",
    "Metal4 860.00 40.00 1644.48 104.36",
    "Metal5 860.00 40.00 1644.48 104.36",
    "TopMetal1 860.00 40.00 1644.48 104.36",

    "Metal3 40.00 599.40 824.48 600.00",
    "Metal3 40.00 664.36 824.48 664.96",
    "Metal3 39.40 600.00 40.00 664.36",
    "Metal3 824.48 600.00 825.08 664.36",
    "Metal2 40.00 664.36 824.48 664.96",
    "Metal2 39.40 600.00 40.00 664.36",
    "Metal2 824.48 600.00 825.08 664.36",
    "Metal4 40.00 600.00 824.48 664.36",
    "Metal5 40.00 600.00 824.48 664.36",
    "TopMetal1 40.00 600.00 824.48 664.36"
  ],

  "//": "SRAM macro DRC/LVS settings",
  "MAGIC_MACRO_STD_CELL_SOURCE": "PDK",
  "MAGIC_EXT_ABSTRACT_CELLS": [
    "RM_IHPSG13_2P_.*",
    "RM_IHPSG13_1P_.*"
  ],

  "//": "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!",
  "//": "!!! DO NOT CHANGE ANYTHING BELOW THIS POINT !!!",
  "//": "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!",

  "//": "Save some time",
  "RUN_KLAYOUT_XOR": 0,
  "RUN_KLAYOUT_DRC": 0,

  "//": "Don't put clock buffers on the outputs",
  "DESIGN_REPAIR_BUFFER_OUTPUT_PORTS": 0,
  "DRT_ANTENNA_REPAIR_ITERS": 1,

  "//": "Reduce wasted space",
  "TOP_MARGIN_MULT": 1,
  "BOTTOM_MARGIN_MULT": 1,
  "LEFT_MARGIN_MULT": 6,
  "RIGHT_MARGIN_MULT": 6,

  "//": "Absolute die size",
  "FP_SIZING": "absolute",

  "GRT_ALLOW_CONGESTION": 1,

  "FP_IO_HLENGTH": 2,
  "FP_IO_VLENGTH": 2,

  "FP_PDN_VPITCH": 38.87,

  "//": "Clock",
  "RUN_CTS": 1,

  "//": "Don't generate power rings",
  "FP_PDN_MULTILAYER": 0,

  "//": "MAGIC_DEF_LABELS may cause issues with LVS",
  "MAGIC_DEF_LABELS": 0,

  "//": "Only export pin area in LEF (without any connected nets)",
  "MAGIC_WRITE_LEF_PINONLY": 1
}
