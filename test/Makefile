# -----------------------------------------------------------------------------
# Gate-level sources
# -----------------------------------------------------------------------------

GL_SOURCES += $(PDK_ROOT)/ihp-sg13g2/libs.ref/sg13g2_io/verilog/sg13g2_io.v
