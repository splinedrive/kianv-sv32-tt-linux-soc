GL_SOURCES += $(SRC_DIR)/RM_IHPSG13_1P_512x64_c2_bm_bist.v

# -----------------------------------------------------------------------------
# Mode selection
# -----------------------------------------------------------------------------

ifeq ($(GATES),yes)

SIM_BUILD = sim_build/gl
VERILOG_SOURCES = $(GL_SOURCES) $(TB_SOURCES)
COMPILE_ARGS += $(COMMON_COMPILE_ARGS)
COMPILE_ARGS += -DGL_TEST

else

SIM_BUILD = sim_build/rtl
VERILOG_SOURCES = $(RTL_SOURCES) $(TB_SOURCES)
COMPILE_ARGS += $(COMMON_COMPILE_ARGS)

endif

