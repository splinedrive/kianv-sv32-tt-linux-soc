# Makefile
# Cocotb simulation Makefile for RTL and Gate-Level simulation

SIM ?= icarus
TOPLEVEL_LANG ?= verilog
TOPLEVEL = tb
COCOTB_TEST_MODULES = test

PWD := $(shell pwd)
SRC_DIR := $(PWD)/../src

# Optional waveform format for icarus
FST ?= -fst

# -----------------------------------------------------------------------------
# Common compile args
# -----------------------------------------------------------------------------

COMMON_COMPILE_ARGS += -I$(SRC_DIR)
COMMON_COMPILE_ARGS += -I$(SRC_DIR)/kianv-sv32-tt
COMMON_COMPILE_ARGS += -DSIM
COMMON_COMPILE_ARGS += -DSYSTEM_CLK=10000000
COMMON_COMPILE_ARGS += -DASIC=1

# -----------------------------------------------------------------------------
# Common testbench sources
# -----------------------------------------------------------------------------

TB_SOURCES += $(PWD)/spiflash.v
