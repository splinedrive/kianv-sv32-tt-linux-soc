# Optional simulator-specific args
# -----------------------------------------------------------------------------
# Optional waveform format for icarus
FST ?= -fst

# -----------------------------------------------------------------------------
# Cocotb rules
# -----------------------------------------------------------------------------

include $(shell cocotb-config --makefiles)/Makefile.sim
