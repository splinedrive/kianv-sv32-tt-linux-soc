# Gate-level netlist generated by the flow
GL_SOURCES += $(PWD)/gate_level_netlist.v

# SRAM behavioral macro models required by the netlist
GL_SOURCES += $(SRC_DIR)/RM_IHPSG13_1P_core_behavioral_bm_bist.v
GL_SOURCES += $(SRC_DIR)/RM_IHPSG13_1P_64x64_c2_bm_bist.v
